START_MSG = "<blockquote><b>ʜᴇʏ {first_name}</b>,</blockquote>\n<i><blockquote>ɪ'ᴍ ᴀɴ ᴀᴜᴛᴏ ᴀɴɪᴍᴇ ꜱᴛᴏʀᴇ & ᴇɴᴄᴏᴅɪɴɢ ʙᴏᴛ, ʙᴜɪʟᴛ ᴡɪᴛʜ ʟᴏᴠᴇ.</blockquote></i>\n\n<blockquote>❝ ɴᴏ ᴍᴀᴛᴛᴇʀ ʜᴏᴡ ᴅᴇᴇᴘ ᴛʜᴇ ɴɪɢʜᴛ, ɪᴛ ᴀʟᴡᴀʏꜱ ᴛᴜʀɴꜱ ᴛᴏ ᴅᴀʏ, ᴇᴠᴇɴᴛᴜᴀʟʟʏ. ᴀꜱ ʟᴏɴɢ ᴀꜱ ʏᴏᴜ ᴅᴏɴ’ᴛ ɢɪᴠᴇ ᴜᴘ, ᴛʜᴇʀᴇ ᴡɪʟʟ ᴀʟᴡᴀʏꜱ ʙᴇ ᴀ ᴘᴀᴛʜ ꜰᴏʀᴡᴀʀᴅ. ❞</blockquote>\n<blockquote>― <i>ᴋᴇɴ ᴋᴀɴᴇᴋɪ</i></blockquote>"
