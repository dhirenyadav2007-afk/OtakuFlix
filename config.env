LOW_END_FFMPEG = 'ffmpeg -i "{}" -progress "{}" -nostats -loglevel warning -c copy -map 0:v -map 0:a -map 0:s -metadata title="OtakuFlix [t.me/OtakuFlix_Net]" -metadata:s:s title="[OtakuFlix]" -metadata:s:a title="[OtakuFlix]" -metadata:s:v title="[OtakuFlix]" "{}" -y'

FFCODE_HDRi = 'ffmpeg -i "{}" -progress "{}" -nostats -loglevel warning -c copy -map 0:v -map 0:a -map 0:s -metadata title="OtakuFlix [t.me/OtakuFlix_Net]" -metadata:s:s title="[OtakuFlix]" -metadata:s:a title="[OtakuFlix]" -metadata:s:v title="[OtakuFlix]" "{}" -y'

FFCODE_1080 = 'ffmpeg -i "{}" -progress "{}" -nostats -loglevel warning -map 0:v -map 0:a -map 0:s? -c:v libx264 -crf 25 -c:s copy -pix_fmt yuv420p -s 1920x1080 -c:a libopus -b:a 96k -ac 2 -preset veryfast -threads 0 -metadata title="OtakuFlix [t.me/OtakuFlix_Net]" -metadata:s:s title="[OtakuFlix]" -metadata:s:a title="[OtakuFlix]" -metadata:s:v title="[OtakuFlix]" -movflags +faststart "{}" -y'

FFCODE_720 = 'ffmpeg -i "{}" -progress "{}" -nostats -loglevel warning -map 0:v -map 0:a -map 0:s? -c:v libx264 -crf 26 -c:s copy -pix_fmt yuv420p -s 1280x720 -c:a libopus -b:a 64k -ac 2 -preset veryfast -threads 0 -metadata title="OtakuFlix [t.me/OtakuFlix_Net]" -metadata:s:s title="[OtakuFlix]" -metadata:s:a title="[OtakuFlix]" -metadata:s:v title="[OtakuFlix]" -movflags +faststart "{}" -y'

FFCODE_480 = 'ffmpeg -i "{}" -progress "{}" -nostats -loglevel warning -map 0:v -map 0:a -map 0:s? -c:v libx264 -crf 27 -c:s copy -pix_fmt yuv420p -s 854x480 -c:a libopus -b:a 42k -ac 2 -preset veryfast -threads 0 -metadata title="OtakuFlix [t.me/OtakuFlix_Net]" -metadata:s:s title="[OtakuFlix]" -metadata:s:a title="[OtakuFlix]" -metadata:s:v title="[OtakuFlix]" -movflags +faststart "{}" -y'

FFCODE_360 = 'ffmpeg -i "{}" -progress "{}" -nostats -loglevel warning -vf "drawtext=text=\'OtakuFlix\':fontcolor=white@0.3:fontsize=14:x=5:y=5" -map 0:v -map 0:a -map 0:s -c:v libx264 -crf 29 -c:s copy -pix_fmt yuv420p -s 640x360 -c:a libopus -b:a 35k -preset veryfast -threads 2 -metadata title="OtakuFlix [t.me/OtakuFlix_Net]" "{}" -y'

QUALS="480 720 1080" # Qualities Separated by Space without "p" ( Sequence Specific )

